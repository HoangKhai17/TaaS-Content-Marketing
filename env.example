# ============================================================
# env.example — Template cấu hình TaaS Content Marketing Skill
# ============================================================
# CÁCH DÙNG:
#   cp env.example .env
#   Điền giá trị thật vào .env (không commit .env lên Git)
#
# Bắt buộc: WP_URL, WP_USERNAME, WP_APP_PASSWORD
# Khuyến nghị: UNSPLASH_ACCESS_KEY
# Tùy chọn: PEXELS_API_KEY, PIXABAY_API_KEY (fallback ảnh)
# ============================================================


# ────────────────────────────────────────
# WORDPRESS — BẮT BUỘC
# ────────────────────────────────────────

# URL website WordPress của bạn (không có dấu / ở cuối)
# Ví dụ: https://blog.company.com hoặc https://company.com
WP_URL=https://your-site.com

# Username tài khoản WordPress Admin
# Dùng tài khoản có quyền "Editor" hoặc "Administrator"
WP_USERNAME=your_wp_username

# Application Password — để tạo/cập nhật bài viết qua REST API
# Cách lấy:
#   1. Đăng nhập WordPress Admin (your-site.com/wp-admin)
#   2. Vào Users → Profile (hoặc Users → All Users → chọn tài khoản)
#   3. Kéo xuống mục "Application Passwords"
#   4. Nhập tên app: "TaaS Content Skill" → click "Add New Application Password"
#   5. Copy password được tạo ra (format: xxxx xxxx xxxx xxxx xxxx xxxx)
#   ⚠️  Password này chỉ hiển thị 1 lần — lưu lại ngay
#   ⚠️  Cần bật HTTPS trên website để Application Passwords hoạt động
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx


# ────────────────────────────────────────
# ẢNH — KHUYẾN NGHỊ ÍT NHẤT 1 NGUỒN
# Fallback tự động: Unsplash → Pexels → Pixabay
# ────────────────────────────────────────

# UNSPLASH (ưu tiên 1) — Ảnh chất lượng cao, miễn phí
# Cách lấy:
#   1. Tạo tài khoản tại unsplash.com/developers
#   2. Click "New Application"
#   3. Điền tên app, đồng ý terms → Submit
#   4. Kéo xuống phần "Keys" → copy "Access Key"
#   ℹ️  Free tier: 50 requests/giờ — đủ dùng
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# PEXELS (ưu tiên 2) — Fallback nếu Unsplash hết quota
# Cách lấy:
#   1. Tạo tài khoản tại pexels.com
#   2. Vào pexels.com/api → "Your API Key"
#   3. Điền form xin key (approve tự động)
#   4. Copy API Key
#   ℹ️  Free: 200 requests/giờ, 20,000 requests/tháng
PEXELS_API_KEY=your_pexels_api_key

# PIXABAY (ưu tiên 3) — Fallback cuối nếu 2 nguồn trên fail
# Cách lấy:
#   1. Tạo tài khoản tại pixabay.com
#   2. Vào pixabay.com/api/docs
#   3. Đăng nhập → API key hiển thị ngay trên trang
#   ℹ️  Free: 100 requests/phút
PIXABAY_API_KEY=your_pixabay_api_key
